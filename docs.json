            "pages": [
              "index",
              "what-is-uip",
              "quickstart",
              "pricing"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/primitives",
              "core-concepts/sessions",
              "core-concepts/wallets",
              "core-concepts/verification",
              "core-concepts/audits",
              "core-concepts/webhooks",
              "core-concepts/security"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/errors"
            ]
          },
          {
            "group": "Sessions",
            "pages": [
              "api-reference/sessions/create",
              "api-reference/sessions/get",
              "api-reference/sessions/continue",
              "api-reference/sessions/stop"
            ]
          },
          {
            "group": "Audits",
            "pages": [
              "api-reference/audits/get"
            ]
          },
          {
            "group": "Wallets",
            "pages": [
              "api-reference/wallets/list"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "UIP Platform",
          "href": "https://uip.digital",
          "icon": "globe"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@uip.digital",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {

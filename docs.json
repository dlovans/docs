{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "UIP Documentation",
  "colors": {
    "primary": "#1E3A8A",
    "light": "#3B82F6",
    "dark": "#60A5FA"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "what-is-uip",
              "quickstart",
              "pricing"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/primitives",
              "core-concepts/sessions",
              "core-concepts/wallets",
              "core-concepts/verification",
              "core-concepts/webhooks",
              "core-concepts/security"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/errors"
            ]
          },
          {
            "group": "Sessions",
            "pages": [
              "api-reference/sessions/create",
              "api-reference/sessions/get",
              "api-reference/sessions/continue",
              "api-reference/sessions/stop"
            ]
          },
          {
            "group": "Wallets",
            "pages": [
              "api-reference/wallets/list"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "UIP Platform",
          "href": "https://uip.digital",
          "icon": "globe"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@uip.digital",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Get API Keys",
        "href": "https://uip.digital/signup"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://uip.digital"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
